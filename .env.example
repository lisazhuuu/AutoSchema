# ---------------------------------------------------------------------------
# AutoSchema credentials and runtime options.
# Copy to .env and fill in for local runs.
# DO NOT commit the real .env file; it is gitignored.
# ---------------------------------------------------------------------------

# Provider: azure_openai (default) or openai
LLM_PROVIDER=azure_openai

# ---------- Chat model ------------------------------------------------------
# Azure OpenAI:
CHAT_DEPLOYMENT=gpt-5.4
CHAT_MODEL=gpt-5.4
CHAT_API_KEY=
CHAT_ENDPOINT=
CHAT_VERSION=2024-12-01-preview

# OpenAI provider fallback:
# If LLM_PROVIDER=openai, you may set either OPENAI_API_KEY or CHAT_API_KEY.
OPENAI_API_KEY=

# ---------- Embeddings ------------------------------------------------------
EMBEDDING_DEPLOYMENT=text-embedding-3-large
EMBEDDING_MODEL=text-embedding-3-large
# Azure-only optional fields; if blank, code falls back to CHAT_*.
EMBEDDING_API_KEY=
EMBEDDING_ENDPOINT=
EMBEDDING_VERSION=2024-12-01-preview

# ---------- Retrieval APIs --------------------------------------------------
# Polite-pool email used by Crossref / Springer-Nature requests.
CROSSREF_MAILTO=
# Polite-pool email used by OpenAlex; falls back to CROSSREF_MAILTO if blank.
OPENALEX_MAILTO=
# NCBI identity used for PubMed eutils. Strongly recommended for PubMed.
NCBI_EMAIL=
# Optional NCBI API key.
NCBI_API_KEY=
# CORE open-access aggregator. If unset and core is requested, CORE is skipped.
CORE_API_KEY=

# ---------- arXiv robustness controls --------------------------------------
# Set to 1 to skip arXiv for the whole run.
ARXIV_DISABLE=0
# Minimum seconds between arXiv API calls; keep >=3, 5 is safer.
ARXIV_MIN_GAP=5.0
# Page-size cap for arXiv API calls.
ARXIV_MAX_PAGE=25
# Number of quick retries after an arXiv 429/503 before continuing.
ARXIV_FAIL_RETRIES=2
# Consecutive 429/503 failures before disabling arXiv for this process.
ARXIV_429_TRIP=3

# ---------- Filesystem overrides (optional) --------------------------------
# AUTOSCHEMA_OUTPUT_DIR=output
# AUTOSCHEMA_TEXT_DIR=output/texts
# AUTOSCHEMA_CONFIG=config/config.yaml
